# Database
POSTGRES_USER=darkweb
POSTGRES_PASSWORD=darkweb_secret
POSTGRES_DB=darkweb_scraper
DATABASE_URL=postgresql+asyncpg://darkweb:darkweb_secret@db:5432/darkweb_scraper

# Redis
REDIS_URL=redis://redis:6379/0

# Selenium
SELENIUM_HUB_URL=http://selenium-chrome:4444/wd/hub

# Tor Proxy
TOR_PROXY_HOST=tor-proxy
TOR_SOCKS_PORT=9050
TOR_HTTP_PORT=8118

# API Settings
API_SECRET_KEY=your-super-secret-key-change-in-production
ENVIRONMENT=development
DEBUG=true

# Scraper Settings
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_COOLDOWN=60

# ===========================================
# Smart Scraping Strategy
# ===========================================
# Default engine: "auto" (BS4 first, escalate if needed), "bs4", or "selenium"
DEFAULT_SCRAPE_ENGINE=auto

# Minimum chars from BS4 before auto-escalating to Selenium
BS4_MIN_CONTENT_LENGTH=200

# ===========================================
# IP Security Settings (IMPORTANT!)
# ===========================================
# Add your real IP addresses here (comma-separated)
# The scraper will ABORT if it detects any of these IPs
# Example: BLACKLISTED_IPS=["203.0.113.1", "198.51.100.1"]
BLACKLISTED_IPS=[]

# If true, scraper will abort if not using a verified Tor exit node
REQUIRE_TOR_EXIT_NODE=true

# ===========================================
# Entity Extraction / LLM Analysis (Optional)
# ===========================================
# Provide an OpenAI API key to enable LLM-based analysis (summary,
# legitimacy scoring, site categorization). Leave empty to use
# regex-only extraction (crypto wallets, emails, PGP, onion links).
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
